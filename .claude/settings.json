{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "test -f .claude/hooks/pre-tool-use/tmux-kill-guard.sh && bash .claude/hooks/pre-tool-use/tmux-kill-guard.sh || exit 0",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -f .claude/hooks/stop/commit-and-pr-guard.sh && bash .claude/hooks/stop/commit-and-pr-guard.sh || exit 0",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "test -f .claude/hooks/stop/revise-loop-guard.sh && bash .claude/hooks/stop/revise-loop-guard.sh || exit 0",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -f .claude/hooks/pre-compact/preserve-skill-state.sh && bash .claude/hooks/pre-compact/preserve-skill-state.sh || exit 0",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
