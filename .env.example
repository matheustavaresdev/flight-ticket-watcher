# Database
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=flight_watcher
POSTGRES_USER=flight_watcher
POSTGRES_PASSWORD=changeme

# Scanner
# How often to run the scan (in minutes)
SCAN_INTERVAL_MINUTES=60
LOG_LEVEL=INFO

# Anti-detection delays (seconds)
MIN_DELAY_SEC=5
MAX_DELAY_SEC=15

# Circuit breaker
CB_FAILURE_THRESHOLD=3

HEALTH_PORT=8080

# Email alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
ALERT_EMAIL_TO=

# Web Dashboard
# DATABASE_URL is composed automatically in docker-compose from the POSTGRES_* vars above.
# For local Next.js dev (outside Docker), create web/.env.local with:
DATABASE_URL="postgresql://flight_watcher:changeme@localhost:5432/flight_watcher"
